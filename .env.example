POSTGRES_USER=sipra
POSTGRES_PASSWORD=sipra_dev
POSTGRES_DB=sipra
DATABASE_URL=postgres://sipra:sipra_dev@localhost:5433/sipra?sslmode=disable
REDIS_URL=redis://127.0.0.1:6379/0

# External APIs (leave blank for mock mode)
GOOGLE_MAPS_API_KEY=
VERTEX_AI_PROJECT=
VERTEX_AI_LOCATION=us-central1

# Service URLs for running the Go core locally while dependencies run in Compose.
AI_BRAIN_URL=http://localhost:8000
MOCK_DRONE_URL=http://localhost:4003
VALHALLA_URL=http://localhost:8002
SIM_TICK_HZ=20
SIM_TICK_STREAM_MAXLEN=20000
CHAOS_ENABLED=true
