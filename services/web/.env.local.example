# Copy this file to .env.local and fill in your values.

# Required: Google Maps JavaScript API key with "Maps JavaScript API" enabled.
# Create one at https://console.cloud.google.com/google/maps-apis/credentials
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# WebSocket URL for the Go backend dashboard hub (default shown).
NEXT_PUBLIC_BACKEND_WS_URL=ws://localhost:8080/ws/dashboard

# HTTP base URL for the Go backend REST API (default shown).
NEXT_PUBLIC_BACKEND_HTTP_URL=http://localhost:8080

# WebSocket URL for the God-mode simulator fleet stream (default shown).
NEXT_PUBLIC_SIM_WS_URL=ws://localhost:4001
