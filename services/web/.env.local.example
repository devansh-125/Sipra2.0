# Copy this file to .env.local and fill in your values.

# Required: Google Maps JavaScript API key with "Maps JavaScript API" enabled.
# Create one at https://console.cloud.google.com/google/maps-apis/credentials
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# WebSocket URL for the Go backend dashboard hub.
NEXT_PUBLIC_BACKEND_WS_URL=ws://localhost:8080/ws/dashboard

# Standalone frontend mode defaults (safe when Go backend is not running).
# Set to "true" only when that integration is actually running locally.
NEXT_PUBLIC_ENABLE_BACKEND_WS=false

# HTTP base URL for the Go backend REST API.
NEXT_PUBLIC_BACKEND_HTTP_URL=http://localhost:8080

# WebSocket URL for the God-mode simulator fleet stream.
NEXT_PUBLIC_SIM_WS_URL=ws://localhost:4001

# Set to "true" only when simulator websocket server is running.
NEXT_PUBLIC_ENABLE_SIM_WS=false

# Set to "true" to call live Google Directions API via /api/route/directions.
# When false, frontend uses pre-recorded routes and avoids 502 noise.
NEXT_PUBLIC_ENABLE_DIRECTIONS_API=false

# UUID of the seeded trip to display in the Mission Control sidebar.
NEXT_PUBLIC_DEMO_TRIP_ID=
